# App mode: desktop | web | demo
APP_MODE=web

# Web server
HOST=127.0.0.1
PORT=3000

# Hosted web database
DATABASE_URL=postgres://novelgraph:novelgraph@localhost:5432/novelgraph

# Desktop/local database
SQLITE_DATABASE_PATH=./data/novelgraph.sqlite3

# Object storage for hosted web
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# BYOK encryption
# Use a real secret in production. Do not commit it.
SECRETS_ENCRYPTION_KEY=

# Local AI for desktop mode
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_DEFAULT_MODEL=qwen3
LLAMA_CPP_TIMEOUT_SECS=120
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECS=120

# Optional provider defaults for web BYOK UI
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-5-mini
